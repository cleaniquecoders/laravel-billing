includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    ignoreErrors:
        # env() in the package config file is correct usage; Larastan can only
        # recognise the host app's config directory, not a package's.
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/billing.php
        # HasSubscriptions is a public-API trait consumed by host app models,
        # so it is never used within the package's own analysed source.
        -
            identifier: trait.unused
            path: src/Concerns/HasSubscriptions.php
        # Larastan cannot resolve the package's runtime-registered `billing::`
        # view namespace during isolated CI analysis, so it reports these literal
        # namespaced view names as plain strings (a view-string false positive —
        # the views exist under resources/views/). reportUnmatched is false: a
        # fully-booted context (local) resolves them with no error to suppress.
        -
            message: '#expects view-string\|null, string given#'
            paths:
                - src/Livewire
                - src/Http/Controllers
            reportUnmatched: false
